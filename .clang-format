BasedOnStyle: LLVM

CommentPragmas: "^ ?(RUN|CHECK|PRAGMA)"

IndentWidth: 4
ColumnLimit: 135
PointerAlignment: Left
NamespaceIndentation: All
AllowShortFunctionsOnASingleLine: Inline
IndentPPDirectives: BeforeHash
IndentCaseLabels: true

IncludeCategories:
    - Regex: '(<|")context.h.*'
      Priority: -2
    - Regex: '(<|")windows.h.*'
      Priority: -1
    - Regex: ".*"
      Priority: 4
